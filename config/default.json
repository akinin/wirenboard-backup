{
  "nfs_server": "10.10.100.11",
  "nfs_export": "/volume1/Backups",
  "nfs_options": "rw,hard,timeo=50,retrans=2,_netdev",
  "mount_point": "/mnt/wb-backup-nas",
  "destination": "WirenBoard",
  "config_backup": {
    "enabled": true,
    "frequency": "daily",
    "weekday": 1,
    "monthday": 1,
    "hour": 3,
    "minute": 30,
    "keep_count": 14
  },
  "full_backup": {
    "enabled": true,
    "frequency": "weekly",
    "weekday": 7,
    "monthday": 1,
    "hour": 4,
    "minute": 30,
    "keep_count": 4
  },
  "mqtt_host": "127.0.0.1",
  "mqtt_port": 1883,
  "mqtt_prefix": "/wirenboard/backup",
  "ha_discovery_prefix": "homeassistant"
}
